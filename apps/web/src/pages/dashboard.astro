---
import Layout from '../layouts/Layout.astro';
import { createApiKey, listApiKeys, revokeApiKey, type CreatedApiKey } from '../lib/api-keys';
import { auth } from '../lib/auth';

export const prerender = false;

const session = await auth.api.getSession({ headers: Astro.request.headers });
if (!session) {
  return Astro.redirect('/login');
}

const userId = session.user.id;
let createdKey: CreatedApiKey | null = null;
let error: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action');
  try {
    if (action === 'create') {
      const name = String(form.get('name') ?? '').slice(0, 60);
      createdKey = await createApiKey(userId, name);
    } else if (action === 'revoke') {
      await revokeApiKey(userId, String(form.get('id') ?? ''));
    }
  } catch {
    error = 'No se pudo completar la operación.';
  }
}

const keys = await listApiKeys(userId);

const fmt = (d: Date | null) =>
  d ? new Date(d).toLocaleString('es-CO', { dateStyle: 'medium', timeStyle: 'short' }) : '—';

---

<Layout title="Dashboard — Factus MCP" description="Panel de API Keys para el servidor MCP de Factus">
  <div style="min-height:100vh;display:flex;flex-direction:column;background:#000;color:#ededed;">

    <!-- TOP NAV -->
    <nav style="height:54px;border-bottom:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;padding:0 24px;gap:0;flex-shrink:0;background:#000;position:sticky;top:0;z-index:50;">
      <a href="/" style="display:flex;align-items:center;gap:8px;text-decoration:none;color:#ededed;">
        <div style="width:28px;height:28px;border-radius:6px;background:#fff;display:flex;align-items:center;justify-content:center;color:#000;font-weight:800;font-size:15px;font-family:'JetBrains Mono',monospace;">f</div>
        <span style="font-weight:600;font-size:14px;letter-spacing:-0.01em;">factus<span style="color:#6e6e6e;">/mcp</span></span>
      </a>
      <div style="flex:1;"></div>
      <span style="font-size:13px;color:#6e6e6e;margin-right:16px;">{session.user.email}</span>
      <button id="logout" type="button" style="background:none;border:1px solid rgba(255,255,255,0.12);color:#a1a1a1;font-size:13px;font-family:'Inter',sans-serif;border-radius:7px;padding:6px 13px;cursor:pointer;transition:border-color .15s,color .15s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.28)';this.style.color='#ededed';" onmouseout="this.style.borderColor='rgba(255,255,255,0.12)';this.style.color='#a1a1a1';">
        Cerrar sesión
      </button>
    </nav>

    <!-- BODY ROW -->
    <div style="display:flex;flex:1;min-height:0;">

      <!-- SIDEBAR -->
      <aside style="width:230px;flex-shrink:0;border-right:1px solid rgba(255,255,255,0.07);padding:24px 16px;display:flex;flex-direction:column;gap:4px;">
        <p style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:#6e6e6e;margin:0 0 10px 8px;">Proyecto</p>
        <a href="/dashboard" style="display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:8px;text-decoration:none;font-size:14px;color:#ededed;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="14" height="10" rx="1.5"/><path d="M4 6h2M4 9h5"/></svg>
          API Keys
        </a>
        <div style="flex:1;"></div>
        <a href="/" style="display:flex;align-items:center;gap:7px;padding:8px 10px;border-radius:8px;text-decoration:none;font-size:13px;color:#6e6e6e;transition:color .15s;" onmouseover="this.style.color='#a1a1a1';" onmouseout="this.style.color='#6e6e6e';">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="10,3 5,8 10,13"/></svg>
          Volver al inicio
        </a>
      </aside>

      <!-- MAIN -->
      <main style="flex:1;padding:34px 36px;overflow-y:auto;min-width:0;">

        {error && (
          <div style="margin-bottom:20px;border:1px solid rgba(248,113,113,0.3);background:rgba(248,113,113,0.07);border-radius:10px;padding:12px 16px;font-size:14px;color:#f87171;">
            {error}
          </div>
        )}

        <!-- HEADER ROW -->
        <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:28px;gap:16px;flex-wrap:wrap;">
          <div>
            <h1 style="font-size:24px;font-weight:700;letter-spacing:-0.03em;margin:0 0 6px;">API Keys</h1>
            <p style="font-size:14px;color:#a1a1a1;margin:0;line-height:1.5;">Crea y gestiona las llaves que autentican tus clientes MCP hacia este servidor.</p>
          </div>
          <button id="open-create-modal" type="button" style="background:#ededed;color:#000;font-size:13px;font-weight:600;border:none;border-radius:8px;padding:9px 16px;cursor:pointer;font-family:'Inter',sans-serif;flex-shrink:0;transition:background .15s;" onmouseover="this.style.background='#fff';" onmouseout="this.style.background='#ededed';">
            + Crear API Key
          </button>
        </div>

        <!-- API KEYS TABLE -->
        <div style="border:1px solid rgba(255,255,255,0.08);border-radius:13px;background:#0a0a0a;overflow:hidden;">
          <div style="display:grid;grid-template-columns:1fr 1fr 140px 140px 100px 80px;padding:10px 18px;border-bottom:1px solid rgba(255,255,255,0.07);gap:12px;">
            <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:#6e6e6e;">Nombre</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:#6e6e6e;">Llave</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:#6e6e6e;">Creada</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:#6e6e6e;">Último uso</span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:#6e6e6e;">Estado</span>
            <span></span>
          </div>
          {keys.length === 0 ? (
            <div style="padding:48px 18px;text-align:center;color:#6e6e6e;font-size:14px;">
              Aún no has creado ninguna API Key. Usa el botón de arriba para crear la primera.
            </div>
          ) : (
            keys.map((key) => (
              <div style="display:grid;grid-template-columns:1fr 1fr 140px 140px 100px 80px;padding:14px 18px;border-bottom:1px solid rgba(255,255,255,0.05);align-items:center;gap:12px;transition:background .12s;" onmouseover="this.style.background='rgba(255,255,255,0.02)';" onmouseout="this.style.background='transparent';">
                <span style="font-size:14px;font-weight:500;color:#ededed;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{key.name || '—'}</span>
                <span style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#a1a1a1;">{key.keyPrefix}•••</span>
                <span style="font-size:12px;color:#6e6e6e;">{fmt(key.createdAt)}</span>
                <span style="font-size:12px;color:#6e6e6e;">{fmt(key.lastUsedAt)}</span>
                <span>
                  {key.revokedAt ? (
                    <span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#8a8a8a;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);border-radius:5px;padding:3px 8px;">Revocada</span>
                  ) : (
                    <span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#37d67a;background:rgba(55,214,122,0.1);border:1px solid rgba(55,214,122,0.28);border-radius:5px;padding:3px 8px;">Activa</span>
                  )}
                </span>
                <span style="text-align:right;">
                  {!key.revokedAt && (
                    <form method="POST" style="display:inline;">
                      <input type="hidden" name="action" value="revoke" />
                      <input type="hidden" name="id" value={key.id} />
                      <button type="submit" style="background:none;border:none;color:#6e6e6e;font-size:12px;cursor:pointer;font-family:'Inter',sans-serif;padding:0;transition:color .15s;" onmouseover="this.style.color='#f87171';" onmouseout="this.style.color='#6e6e6e';">Revocar</button>
                    </form>
                  )}
                </span>
              </div>
            ))
          )}
        </div>

      </main>
    </div>
  </div>

  <!-- CREATE MODAL -->
  <div id="modal-overlay" style="display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);align-items:center;justify-content:center;padding:24px;">
    <div id="modal-box" style="background:#0a0a0a;border:1px solid rgba(255,255,255,0.12);border-radius:16px;width:100%;max-width:440px;overflow:hidden;">

      <!-- CREATE STATE -->
      <div id="modal-create">
        <div style="padding:22px 24px;border-bottom:1px solid rgba(255,255,255,0.07);display:flex;align-items:center;justify-content:space-between;">
          <h2 style="font-size:17px;font-weight:700;letter-spacing:-0.02em;margin:0;">Nueva API Key</h2>
          <button id="close-modal" type="button" style="background:none;border:none;color:#6e6e6e;font-size:20px;cursor:pointer;line-height:1;padding:0;transition:color .15s;" onmouseover="this.style.color='#ededed';" onmouseout="this.style.color='#6e6e6e';">×</button>
        </div>
        <form method="POST" id="create-form" style="padding:22px 24px;">
          <input type="hidden" name="action" value="create" />
          <label style="display:block;font-size:13px;color:#a1a1a1;margin-bottom:8px;">Nombre de la key</label>
          <input type="text" name="name" placeholder="ej. Claude Code – producción" maxlength="60" required style="width:100%;background:#111;border:1px solid rgba(255,255,255,0.14);color:#ededed;font-size:14px;font-family:'Inter',sans-serif;border-radius:8px;padding:10px 13px;outline:none;transition:border-color .15s;box-sizing:border-box;" onfocus="this.style.borderColor='rgba(255,255,255,0.35)';" onblur="this.style.borderColor='rgba(255,255,255,0.14)';" />
          <p style="font-size:12px;color:#6e6e6e;margin:10px 0 20px;line-height:1.5;">Elige un nombre descriptivo. La key solo se muestra una vez después de crearla.</p>
          <div style="display:flex;gap:10px;justify-content:flex-end;">
            <button type="button" id="cancel-modal" style="background:none;border:1px solid rgba(255,255,255,0.12);color:#a1a1a1;font-size:13px;font-family:'Inter',sans-serif;border-radius:7px;padding:8px 16px;cursor:pointer;transition:border-color .15s,color .15s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.28)';this.style.color='#ededed';" onmouseout="this.style.borderColor='rgba(255,255,255,0.12)';this.style.color='#a1a1a1';">Cancelar</button>
            <button type="submit" style="background:#ededed;color:#000;font-size:13px;font-weight:600;border:none;border-radius:7px;padding:8px 18px;cursor:pointer;font-family:'Inter',sans-serif;transition:background .15s;" onmouseover="this.style.background='#fff';" onmouseout="this.style.background='#ededed';">Crear</button>
          </div>
        </form>
      </div>

      <!-- SUCCESS STATE -->
      <div id="modal-success" style="display:none;">
        <div style="padding:22px 24px;border-bottom:1px solid rgba(255,255,255,0.07);display:flex;align-items:center;justify-content:space-between;">
          <h2 style="font-size:17px;font-weight:700;letter-spacing:-0.02em;margin:0;">API Key creada</h2>
          <button id="close-success-modal" type="button" style="background:none;border:none;color:#6e6e6e;font-size:20px;cursor:pointer;line-height:1;padding:0;transition:color .15s;" onmouseover="this.style.color='#ededed';" onmouseout="this.style.color='#6e6e6e';">×</button>
        </div>
        <div style="padding:22px 24px;">
          <div style="border:1px solid rgba(55,214,122,0.25);background:rgba(55,214,122,0.06);border-radius:9px;padding:12px 14px;margin-bottom:16px;display:flex;align-items:flex-start;gap:10px;">
            <span style="color:#37d67a;font-size:16px;flex-shrink:0;margin-top:1px;">⚠</span>
            <p style="font-size:13px;color:#37d67a;margin:0;line-height:1.5;">Copia tu API Key ahora. No se volverá a mostrar.</p>
          </div>
          <div style="position:relative;border:1px solid rgba(255,255,255,0.1);border-radius:9px;background:#111;overflow:hidden;">
            <code id="plain-key-display" style="display:block;padding:12px 48px 12px 14px;font-family:'JetBrains Mono',monospace;font-size:13px;color:#ededed;word-break:break-all;line-height:1.6;">
              {createdKey ? createdKey.plainKey : ''}
            </code>
            <button id="copy-key-btn" type="button" style="position:absolute;top:8px;right:8px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.14);color:#a1a1a1;font-size:11px;font-family:'JetBrains Mono',monospace;border-radius:5px;padding:3px 8px;cursor:pointer;transition:all .15s;" onmouseover="this.style.background='rgba(255,255,255,0.14)';this.style.color='#ededed';" onmouseout="this.style.background='rgba(255,255,255,0.08)';this.style.color='#a1a1a1';">Copiar</button>
          </div>
          <p style="font-size:12px;color:#6e6e6e;margin:12px 0 20px;line-height:1.5;">Úsala como Bearer token en el header <code style="font-family:'JetBrains Mono',monospace;color:#a1a1a1;">Authorization</code> de tu cliente MCP.</p>
          <div style="display:flex;justify-content:flex-end;">
            <button type="button" id="done-modal" style="background:#ededed;color:#000;font-size:13px;font-weight:600;border:none;border-radius:7px;padding:8px 18px;cursor:pointer;font-family:'Inter',sans-serif;transition:background .15s;" onmouseover="this.style.background='#fff';" onmouseout="this.style.background='#ededed';">Listo</button>
          </div>
        </div>
      </div>

    </div>
  </div>

</Layout>

<script is:inline define:vars={{ hasCreatedKey: !!createdKey, plainKey: createdKey?.plainKey ?? '' }}>
  // ── Logout ──────────────────────────────────────────────
  document.getElementById('logout')?.addEventListener('click', async () => {
    await fetch('/api/auth/sign-out', { method: 'POST', credentials: 'include' });
    window.location.href = '/';
  });

  // ── Modal helpers ────────────────────────────────────────
  const overlay = document.getElementById('modal-overlay');
  const createPanel = document.getElementById('modal-create');
  const successPanel = document.getElementById('modal-success');
  const plainKeyDisplay = document.getElementById('plain-key-display');

  function showModal(state) {
    if (!overlay || !createPanel || !successPanel) return;
    overlay.style.display = 'flex';
    createPanel.style.display = state === 'create' ? '' : 'none';
    successPanel.style.display = state === 'success' ? '' : 'none';
  }

  function hideModal() {
    if (!overlay) return;
    overlay.style.display = 'none';
  }

  // Open create modal
  document.getElementById('open-create-modal')?.addEventListener('click', () => showModal('create'));

  // Close buttons
  document.getElementById('close-modal')?.addEventListener('click', hideModal);
  document.getElementById('cancel-modal')?.addEventListener('click', hideModal);
  document.getElementById('close-success-modal')?.addEventListener('click', hideModal);
  document.getElementById('done-modal')?.addEventListener('click', hideModal);

  // Close on overlay click
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) hideModal();
  });

  // ── Copy key button ──────────────────────────────────────
  document.getElementById('copy-key-btn')?.addEventListener('click', () => {
    const text = plainKeyDisplay?.textContent?.trim() ?? '';
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copy-key-btn');
      if (btn) {
        btn.textContent = '¡Copiado!';
        setTimeout(() => { btn.textContent = 'Copiar'; }, 2000);
      }
    });
  });

  // ── Auto-show success modal if key was just created ──────
  if (hasCreatedKey && plainKey) {
    if (plainKeyDisplay) plainKeyDisplay.textContent = plainKey;
    showModal('success');
  }
</script>
