---
import ConnectSection from '../components/ConnectSection.astro';
import ArchitectureFlow from '../components/ArchitectureFlow.astro';
import DemoSection from '../components/DemoSection.astro';
import Hero from '../components/Hero.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteNav from '../components/SiteNav.astro';
import ToolsSection from '../components/ToolsSection.astro';
import Layout from '../layouts/Layout.astro';
import { landingData, snippets, tools } from '../data/landing';
import { defaultLang, ui, useTranslations, type Lang } from '../i18n/ui';

const lang: Lang = defaultLang;
const t = useTranslations(lang);
const data = landingData[lang];
---

<Layout title={t.metaTitle} description={t.metaDescription} lang={lang}>
  <SiteNav t={t} lang={lang} />
  <main>
    <Hero t={t} />
    <DemoSection t={t} scenarios={data.scenarios} />
    <ArchitectureFlow t={t} />
    <ToolsSection t={t} groups={data.toolGroups} tools={tools} />
    <ConnectSection t={t} />
  </main>
  <SiteFooter t={t} />
</Layout>

<script is:inline define:vars={{ messages: ui, landing: landingData, snippetData: snippets }}>
  if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
  if (window.location.hash) {
    history.replaceState(null, '', `${window.location.pathname}${window.location.search}`);
  }
  window.scrollTo({ top: 0, left: 0, behavior: 'auto' });
  window.addEventListener('pageshow', () => window.scrollTo({ top: 0, left: 0, behavior: 'auto' }), { once: true });

  const state = {
    lang: localStorage.getItem('factus-lang') || document.documentElement.lang || 'es',
    tab: 'claude',
    scenario: 'invoice',
    demoReady: false,
    timers: [],
    activeStep: 0,
    typingTimers: {},
  };

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const promptTypingMs = 32;
  const responseTypingMs = 24;
  const $ = (selector) => document.querySelector(selector);
  const $$ = (selector) => Array.from(document.querySelectorAll(selector));

  function clearTimers() {
    state.timers.forEach((timer) => window.clearTimeout(timer));
    state.timers = [];
    Object.values(state.typingTimers).forEach((timer) => window.clearTimeout(timer));
    state.typingTimers = {};
    $$('.demo-terminal-line.is-typing').forEach((line) => line.classList.remove('is-typing'));
  }

  function wait(ms, fn) {
    const timer = window.setTimeout(fn, reduceMotion ? 1 : ms);
    state.timers.push(timer);
  }

  function getScenario(key) {
    return landing[state.lang].scenarios.find((scenario) => scenario.key === key) || landing[state.lang].scenarios[0];
  }

  function setText(selector, value) {
    const el = $(selector);
    if (el) el.textContent = value;
  }

  function applyLang(lang) {
    state.lang = messages[lang] ? lang : 'es';
    localStorage.setItem('factus-lang', state.lang);
    document.documentElement.lang = state.lang;

    $$('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (key && messages[state.lang][key]) el.textContent = messages[state.lang][key];
    });

    $$('.lang-switch button').forEach((button) => {
      button.classList.toggle('active', button.getAttribute('data-lang') === state.lang);
    });

    renderToolsCopy();
    renderDemoCards();
    setTab(state.tab);
    if (state.demoReady) runDemo(state.scenario, { skipTyping: true, scrollCard: false });
  }

  function renderDemoCards() {
    const scenarios = landing[state.lang].scenarios;
    $$('.demo-scenario-chip').forEach((button, index) => {
      const scenario = scenarios[index];
      if (!scenario) return;
      button.setAttribute('data-scenario', scenario.key);
      const label = button.querySelector('span');
      if (label) label.textContent = scenario.label;
    });
    syncDemoCards();
  }

  function syncDemoCards() {
    $$('.demo-scenario-chip').forEach((button) => {
      const isActive = button.getAttribute('data-scenario') === state.scenario;
      button.classList.toggle('active', isActive);
      button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
    });
  }

  function renderToolsCopy() {
    const groups = landing[state.lang].toolGroups;
    $$('.tool-group').forEach((groupEl, groupIndex) => {
      const group = groups[groupIndex];
      if (!group) return;
      const header = groupEl.querySelector('header');
      if (header) {
        const title = header.querySelector('h3');
        const desc = header.querySelector('p');
        if (title) title.textContent = group.label;
        if (desc) desc.textContent = group.description;
      }
      groupEl.querySelectorAll('.tool-card p').forEach((desc, index) => {
        desc.textContent = group.descs[index] || '';
      });
    });
  }

  function typingDelay(text, index, baseDelay) {
    const char = text[index - 1] || '';
    if (char === '.' || char === ',' || char === ';') return baseDelay + 80;
    if (char === ' ') return Math.max(18, baseDelay - 8);
    return baseDelay;
  }

  function typingDuration(text, baseDelay) {
    return Array.from({ length: text.length }, (_, index) => typingDelay(text, index + 1, baseDelay)).reduce((total, delay) => total + delay, 0);
  }

  function setTyping(key, isTyping) {
    const line = key === 'prompt' ? $('.demo-terminal-line--prompt') : $('.demo-terminal-line--response');
    if (line) line.classList.toggle('is-typing', isTyping);
  }

  function typeText(selector, text, key, skipTyping) {
    const target = $(selector);
    if (!target) return;
    if (state.typingTimers[key]) window.clearTimeout(state.typingTimers[key]);
    delete state.typingTimers[key];
    if (skipTyping || reduceMotion) {
      target.textContent = text;
      setTyping(key, false);
      return;
    }
    target.textContent = '';
    let index = 0;
    const baseDelay = key === 'response' ? responseTypingMs : promptTypingMs;
    setTyping(key, true);
    const tick = () => {
      index += 1;
      target.textContent = text.slice(0, index);
      if (index < text.length) {
        state.typingTimers[key] = window.setTimeout(tick, typingDelay(text, index, baseDelay));
      } else {
        delete state.typingTimers[key];
        setTyping(key, false);
      }
    };
    state.typingTimers[key] = window.setTimeout(tick, typingDelay(text, 0, baseDelay));
  }

  function renderDemo(scenario, options = {}) {
    setText('#demo-title', scenario.label);
    if (!options.keepPrompt) typeText('#demo-prompt', scenario.prompt, 'prompt', options.skipTyping);
    const toolName = scenario.toolName.startsWith('factus_') ? scenario.toolName : `factus_${scenario.toolName}`;
    setText('#demo-tool', state.activeStep >= 1 ? `tool: ${toolName}` : '');
    const complete = state.activeStep >= 2;
    typeText('#demo-response', complete ? scenario.response : '', 'response', !options.typeResponse);

    $$('.demo-terminal-line').forEach((step, index) => {
      const status = index < state.activeStep ? 'complete' : index === state.activeStep ? 'active' : 'pending';
      step.classList.toggle('complete', status === 'complete');
      step.classList.toggle('active', status === 'active');
    });

    const status = $('#demo-status');
    if (status) {
      status.textContent = complete ? 'Factus OK' : messages[state.lang].demoThinking;
      status.classList.toggle('complete', complete);
      status.classList.toggle('running', !complete);
    }
  }

  function runDemo(key, options = {}) {
    clearTimers();
    state.scenario = key;
    state.activeStep = reduceMotion ? 2 : 0;
    const scenario = getScenario(key);
    syncDemoCards();

    renderDemo(scenario, { ...options, typeResponse: reduceMotion });
    if (reduceMotion) return;

    const firstStepDelay = typingDuration(scenario.prompt, promptTypingMs) + 450;
    wait(firstStepDelay, () => {
      state.activeStep = 1;
      renderDemo(scenario, { keepPrompt: true });
    });
    wait(firstStepDelay + 1050, () => {
      state.activeStep = 2;
      renderDemo(scenario, { keepPrompt: true, typeResponse: true });
    });
  }

  function setTab(tab) {
    state.tab = tab;
    $$('.connect-tabs button').forEach((button) => {
      button.classList.toggle('active', button.getAttribute('data-tab') === tab);
    });
    setText('#connect-code', snippetData[tab] || '');
  }

  function initAppearEffects() {
    const targets = $$('.section-appear');
    if (!('IntersectionObserver' in window) || reduceMotion) {
      targets.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    targets.forEach((el) => observer.observe(el));
  }

  function initDemoWhenVisible() {
    const demo = $('#demo');
    if (!demo) return;

    const startDemo = () => {
      if (state.demoReady) return;
      state.demoReady = true;
      runDemo(state.scenario);
    };

    if (!('IntersectionObserver' in window)) {
      startDemo();
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      if (entries.some((entry) => entry.isIntersecting)) {
        observer.disconnect();
        startDemo();
      }
    }, { rootMargin: '0px 0px -18% 0px', threshold: 0.28 });

    observer.observe(demo);
  }

  document.addEventListener('click', (event) => {
    const target = event.target.closest('button, a');
    if (!target) return;

    const lang = target.getAttribute('data-lang');
    if (lang) applyLang(lang);

    const tab = target.getAttribute('data-tab');
    if (tab) setTab(tab);

    const scenario = target.getAttribute('data-scenario');
    if (scenario) {
      state.demoReady = true;
      runDemo(scenario);
    }

    if (target.id === 'connect-copy') {
      navigator.clipboard.writeText(snippetData[state.tab] || '').then(() => {
        target.textContent = messages[state.lang].copied;
        wait(1400, () => { target.textContent = messages[state.lang].copy; });
      });
    }
  });

  initAppearEffects();
  initDemoWhenVisible();
  applyLang(state.lang);
</script>
