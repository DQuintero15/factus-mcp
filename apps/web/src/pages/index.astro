---
import Layout from '../layouts/Layout.astro';
import { auth } from '../lib/auth';

export const prerender = false;

// Si ya hay sesion, ir directo al panel.
const session = await auth.api.getSession({ headers: Astro.request.headers });
if (session) {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Iniciar sesion - Factus MCP">
  <section class="mx-auto max-w-md rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900">Inicia sesion</h2>
    <p class="mt-2 text-sm text-slate-500">
      Accede para crear y administrar las API Keys que tus clientes MCP usaran para conectarse.
    </p>

    <button
      id="google-login"
      class="mt-6 flex w-full items-center justify-center gap-3 rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-50"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
        <path
          fill="#4285F4"
          d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.27-4.74 3.27-8.1Z"
        ></path>
        <path
          fill="#34A853"
          d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z"
        ></path>
        <path
          fill="#FBBC05"
          d="M5.84 14.1a6.6 6.6 0 0 1 0-4.2V7.06H2.18a11 11 0 0 0 0 9.88l3.66-2.84Z"></path>
        <path
          fill="#EA4335"
          d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A11 11 0 0 0 2.18 7.06l3.66 2.84C6.71 7.3 9.14 5.38 12 5.38Z"
        ></path>
      </svg>
      Continuar con Google
    </button>

    <p id="login-error" class="mt-4 hidden text-sm text-red-600"></p>
  </section>
</Layout>

<script>
  import { authClient } from '../lib/auth-client';

  const button = document.getElementById('google-login') as HTMLButtonElement | null;
  const errorEl = document.getElementById('login-error');

  button?.addEventListener('click', async () => {
    button.disabled = true;
    try {
      await authClient.signIn.social({ provider: 'google', callbackURL: '/dashboard' });
    } catch (err) {
      if (errorEl) {
        errorEl.textContent = 'No se pudo iniciar sesion. Revisa la configuracion de Google OAuth.';
        errorEl.classList.remove('hidden');
      }
      button.disabled = false;
    }
  });
</script>
